# Test environment — disables all external services
NODE_ENV=test
PORT=3099
JWT_SECRET=test-jwt-secret-for-e2e-tests
ADMIN_SECRET=test-admin-secret

# Database — uses the same Neon DB (test tenants are isolated + cleaned up)
# DATABASE_URL is inherited from parent .env
# PG_APP_USER is inherited from parent .env
# PG_APP_PASSWORD is inherited from parent .env

# Stripe — use test-mode keys (inherited from parent .env)
# STRIPE_SECRET_KEY inherited
# VITE_STRIPE_PUBLISHABLE_KEY inherited

# Disabled external services — empty keys cause silent skip
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RESEND_API_KEY=
XAI_API_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=
