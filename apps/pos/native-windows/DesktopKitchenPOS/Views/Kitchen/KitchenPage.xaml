<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DesktopKitchenPOS.Views.Kitchen.KitchenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BackgroundBrush}" Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Kitchen Display" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="PendingBadge" FontSize="14"
                           Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                <Button Click="OnPOSClick" Background="Transparent" BorderBrush="Transparent">
                    <FontIcon Glyph="&#xEDA2;" Foreground="{StaticResource TextSecondaryBrush}" FontSize="18" />
                </Button>
                <Button Click="OnLogoutClick" Background="Transparent" BorderBrush="Transparent">
                    <FontIcon Glyph="&#xE7E8;" Foreground="{StaticResource TextSecondaryBrush}" FontSize="18" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="True"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Foreground="{StaticResource AccentBrush}" />

        <TextBlock x:Name="EmptyText" Grid.Row="1" Text="No active orders"
                   FontSize="16" Foreground="{StaticResource TextTertiaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />

        <GridView x:Name="OrdersGrid" Grid.Row="1" SelectionMode="None" Margin="0,12,0,0">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="320" ItemHeight="Auto" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>
    </Grid>
</UserControl>
