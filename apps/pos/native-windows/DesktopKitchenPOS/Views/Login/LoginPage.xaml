<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DesktopKitchenPOS.Views.Login.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BackgroundBrush}">
        <!-- Settings button (top-right) -->
        <Button x:Name="SettingsBtn" Click="OnSettingsClick"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16"
                Background="Transparent" BorderBrush="Transparent">
            <FontIcon Glyph="&#xE713;" Foreground="{StaticResource TextTertiaryBrush}" />
        </Button>

        <!-- Center content -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <TextBlock Text="Desktop Kitchen POS"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Enter your PIN to log in"
                       FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />

            <!-- PIN dots -->
            <StackPanel x:Name="PinDotsPanel" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,24,0,8" Spacing="16" />

            <!-- Error message -->
            <TextBlock x:Name="ErrorText" FontSize="12"
                       Foreground="{StaticResource ErrorBrush}"
                       HorizontalAlignment="Center" Visibility="Collapsed" />

            <!-- Loading -->
            <ProgressRing x:Name="LoadingRing" IsActive="False"
                          Width="32" Height="32" HorizontalAlignment="Center"
                          Foreground="{StaticResource AccentBrush}" />

            <!-- Numpad -->
            <Grid HorizontalAlignment="Center" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="84" />
                </Grid.ColumnDefinitions>

                <!-- Row 1 -->
                <Button Grid.Row="0" Grid.Column="0" Content="1" Click="OnDigitClick" Tag="1" Style="{StaticResource NumpadButtonStyle}" />
                <Button Grid.Row="0" Grid.Column="1" Content="2" Click="OnDigitClick" Tag="2" Style="{StaticResource NumpadButtonStyle}" />
                <Button Grid.Row="0" Grid.Column="2" Content="3" Click="OnDigitClick" Tag="3" Style="{StaticResource NumpadButtonStyle}" />
                <!-- Row 2 -->
                <Button Grid.Row="1" Grid.Column="0" Content="4" Click="OnDigitClick" Tag="4" Style="{StaticResource NumpadButtonStyle}" />
                <Button Grid.Row="1" Grid.Column="1" Content="5" Click="OnDigitClick" Tag="5" Style="{StaticResource NumpadButtonStyle}" />
                <Button Grid.Row="1" Grid.Column="2" Content="6" Click="OnDigitClick" Tag="6" Style="{StaticResource NumpadButtonStyle}" />
                <!-- Row 3 -->
                <Button Grid.Row="2" Grid.Column="0" Content="7" Click="OnDigitClick" Tag="7" Style="{StaticResource NumpadButtonStyle}" />
                <Button Grid.Row="2" Grid.Column="1" Content="8" Click="OnDigitClick" Tag="8" Style="{StaticResource NumpadButtonStyle}" />
                <Button Grid.Row="2" Grid.Column="2" Content="9" Click="OnDigitClick" Tag="9" Style="{StaticResource NumpadButtonStyle}" />
                <!-- Row 4 -->
                <Button Grid.Row="3" Grid.Column="0" Content="C" Click="OnClearClick" Style="{StaticResource NumpadButtonStyle}" />
                <Button Grid.Row="3" Grid.Column="1" Content="0" Click="OnDigitClick" Tag="0" Style="{StaticResource NumpadButtonStyle}" />
                <Button Grid.Row="3" Grid.Column="2" Click="OnBackspaceClick" Style="{StaticResource NumpadButtonStyle}">
                    <FontIcon Glyph="&#xE750;" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
