<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Card background -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#171717" />
    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#262626" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0A0A" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="White" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A3A3A3" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#737373" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#DC2626" />

    <!-- Border -->
    <SolidColorBrush x:Key="BorderBrush" Color="#262626" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#404040" />

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="InfoBrush" Color="#2563EB" />

    <!-- Numpad button style -->
    <Style x:Key="NumpadButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="72" />
        <Setter Property="Height" Value="72" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
